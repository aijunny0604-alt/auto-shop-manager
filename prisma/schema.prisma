generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── 재고 관리 ──

model InventoryItem {
  id          String   @id @default(cuid())
  name        String
  category    String
  quantity    Int      @default(0)
  minQuantity Int      @default(5)
  unitPrice   Int      @default(0)
  location    String?
  memo        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stockLogs       StockLog[]
  servicePartUsed ServicePartUsed[]

  @@index([category])
  @@index([quantity])
}

model StockLog {
  id              String        @id @default(cuid())
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  type            String
  quantity        Int
  reason          String?
  createdAt       DateTime      @default(now())

  @@index([inventoryItemId, createdAt])
}

// ── 고객 관리 ──

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  memo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicles     Vehicle[]
  reservations Reservation[]
  estimates    Estimate[]

  @@index([name])
}

model Vehicle {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  carModel    String
  year        Int?
  plateNumber String?
  vin         String?
  mileage     Int?
  memo        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  serviceRecords ServiceRecord[]
  reservations   Reservation[]
  estimates      Estimate[]
}

model ServiceRecord {
  id          String   @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  serviceDate DateTime
  serviceType String
  description String
  cost        Int      @default(0)
  memo        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  partsUsed ServicePartUsed[]
}

model ServicePartUsed {
  id              String        @id @default(cuid())
  serviceRecordId String
  serviceRecord   ServiceRecord @relation(fields: [serviceRecordId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  quantity        Int
}

// ── 임포트 이력 ──

model ImportHistory {
  id           String   @id @default(cuid())
  fileName     String
  fileType     String   // "csv" | "xlsx"
  rowCount     Int
  successCount Int
  errorCount   Int
  status       String   // "SUCCESS" | "PARTIAL" | "FAILED"
  errors       String?  // JSON array of error messages
  createdAt    DateTime @default(now())
}

// ── Google OAuth 토큰 ──

model GoogleToken {
  id        String   @id @default("default")
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── 예약 관리 ──

model Reservation {
  id              String   @id @default(cuid())
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id])
  vehicleId       String?
  vehicle         Vehicle? @relation(fields: [vehicleId], references: [id])
  scheduledAt     DateTime
  duration        Int      @default(60)
  serviceType     String
  description     String?
  status          String   @default("PENDING")
  calendarEventId String?
  memo            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([scheduledAt])
  @@index([customerId])
  @@index([status])
}

// ── 견적서 관리 ──

model Estimate {
  id          String    @id @default(cuid())
  estimateNo  String    @unique
  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id])
  vehicleId   String?
  vehicle     Vehicle?  @relation(fields: [vehicleId], references: [id])
  status      String    @default("DRAFT")
  validUntil  DateTime?
  totalAmount Int       @default(0)
  discount    Int       @default(0)
  memo        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  items EstimateItem[]

  @@index([customerId])
  @@index([estimateNo])
  @@index([createdAt])
}

model EstimateItem {
  id              String    @id @default(cuid())
  estimateId      String
  estimate        Estimate  @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  type            String
  name            String
  inventoryItemId String?
  quantity        Int       @default(1)
  unitPrice       Int       @default(0)
  amount          Int       @default(0)
  memo            String?
  sortOrder       Int       @default(0)
}
